# notification 인스턴스 .env — *_HOST 는 Infra 인스턴스 프라이빗 IP
NOTIFICATION_IMAGE=<ECR_REGISTRY>/dms-notification:latest

# --- DB (Infra의 MySQL, notification 전용 DB) ---
NOTIFICATION_MYSQL_HOST=10.0.10.7
NOTIFICATION_DB_PORT=3306
NOTIFICATION_DB_NAME=prod_notification
NOTIFICATION_MYSQL_USERNAME=dms
NOTIFICATION_MYSQL_PASSWORD=change-me-db

# --- RabbitMQ (Infra) ---
RABBITMQ_HOST=10.0.10.7
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=dms
RABBITMQ_PASSWORD=change-me-rabbit

# --- 시크릿 ---
PASSPORT_SECRET_KEY=change-me-passport-key

# --- FCM (base64 인코딩한 서비스 계정 JSON) / Slack ---
FCM_BASE64_STRING=change-me-fcm-base64
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/null/null/null
SENTRY_DSN=

# --- 기타 ---
QUARTZ_CLUSTERED=false
FLYWAY_ENABLED=false
BASELINE_ON_MIGRATE=true
