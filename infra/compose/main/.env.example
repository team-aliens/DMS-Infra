# main 인스턴스 .env — *_HOST 는 Infra 인스턴스 프라이빗 IP (terraform output)
MAIN_IMAGE=<ECR_REGISTRY>/dms-main:latest

# --- DB (Infra의 MySQL) ---
MAIN_MYSQL_HOST=10.0.10.7
MAIN_DB_PORT=3306
MAIN_DB_NAME=prod_dms
MAIN_MYSQL_USERNAME=dms
MAIN_MYSQL_PASSWORD=change-me-db

# --- Redis (Infra) ---
REDIS_HOST=10.0.10.7
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

# --- RabbitMQ (Infra) ---
RABBITMQ_HOST=10.0.10.7
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=dms
RABBITMQ_PASSWORD=change-me-rabbit

# --- 시크릿/토큰 ---
SECRET_KEY=change-me-secret-key
PASSPORT_SECRET_KEY=change-me-passport-key
ACCESS_EXP=3600
REFRESH_EXP=1205600

# --- S3 ---
# 인스턴스 IAM 역할(S3 권한)을 쓰는 경우 AWS_ACCESS/AWS_SECRET 는 비워두고
# 앱이 인스턴스 프로파일을 쓰도록 설정. (앱 기본값이 "access"/"secret" 이라 빈 값 주의)
S3_BUCKET_NAME=dms-prod-files-team-aliens
AWS_REGION=ap-northeast-2
AWS_ACCESS=
AWS_SECRET=

# --- 메일 (기존 Gmail SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=2024teamdms@gmail.com
MAIL_PASSWORD=change-me-gmail-app-password

# --- 기타 ---
NEIS_KEY=change-me
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/null/null/null
SENTRY_DSN=
QUARTZ_CLUSTERED=false
MAIN_PROD_SHOW_SQL=false
BASELINE_ON_MIGRATE=true
