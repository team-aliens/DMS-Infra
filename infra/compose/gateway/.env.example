# gateway 인스턴스 .env
# ECR 이미지 (예: 123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/dms-gateway:latest)
GATEWAY_IMAGE=<ECR_REGISTRY>/dms-gateway:latest

# Main / Notification 인스턴스의 프라이빗 IP (terraform output 으로 확인)
MAIN_SERVICE_URL=http://10.0.10.4:8081
NOTIFICATION_SERVICE_URL=http://10.0.10.6:8082

# 앱 시크릿 (운영용 값으로 교체)
SECRET_KEY=change-me-secret-key
PASSPORT_SECRET_KEY=change-me-passport-key
