# infra 인스턴스 .env — 실제 값으로 채운 뒤 .env 로 복사 (커밋 금지)

# ----- MySQL main (3306) -----
MAIN_ROOT_PASSWORD=change-me-main-root
MAIN_DB_NAME=prod_dms

# ----- MySQL notification (3307) -----
NOTI_ROOT_PASSWORD=change-me-noti-root
NOTI_DB_NAME=prod_notification

# ----- 공통 앱 계정 (두 DB 모두 동일 user/password 사용) -----
DB_APP_USER=dms
DB_APP_PASSWORD=change-me-db

REDIS_PASSWORD=change-me-redis

RABBITMQ_USERNAME=dms
RABBITMQ_PASSWORD=change-me-rabbit

# ----- DB 백업 (S3) -----
# BACKUP_S3_BUCKET 은 terraform 의 s3_bucket_name 과 동일해야 한다.
# AWS 자격증명은 인스턴스 프로파일(IMDS)로 자동 사용하므로 키를 적지 않는다.
BACKUP_S3_BUCKET=dms-prod-uploads
BACKUP_S3_PREFIX=backups/mysql
BACKUP_AWS_REGION=ap-northeast-2
# 백업 주기(초). 86400=24h, 21600=6h
BACKUP_INTERVAL=86400
